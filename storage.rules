rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Mirror Firestore admin allowlist by checking custom claims or maintain
      // a duplicate claim. Storage rules cannot read Firestore documents.
      //
      // TODO (recommended): Use custom claims: request.auth.token.admin == true
      return signedIn() && request.auth.token.admin == true;
    }

    // Public read for media; admin-only writes.
    match /club_media/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

